pipeline {
    agent any
    parameters {
        string(name: 'spring', defaultValue: 'build', description: 'build-spring')
    }
    triggers {
        pollSCM('*/2 * * * *')
    }
    environment {
        DEV_TEAM = 'dasswagatika411@gmail.com'
        BUILD_INFO = "Job_Name: ${env.JOB_NAME}\nBuild_Number: ${env.BUILD_NUMBER}"
    }
    options {
        buildDiscarder(logRotator(numToKeepStr: '7'))
    }
    stages {
        stage('git-clone') {
            steps {
              git 'https://github.com/SwagatikaDas01/mavenproject.git'
            }
        }
        stage('maven-project') {
            steps {
                bat 'mvn package'
            }
        }
    }
    post {
        success {
            mail bcc: '', 
            body: """Hello Team,
The Jenkins build has succeeded
${env.BUILD_INFO}

Regards,
DevOps Team""", 
        cc: "${env.DEV_TEAM}", 
        from: '', 
        replyTo: '', 
        subject: "Jenkins Build Success: ${env.JOB_NAME}", 
        to: 'dasswagatika411@gmail.com'
        }
        failure {
            mail bcc: '', 
            body: """Hello Team,
The Jenkins build has Failed
${env.BUILD_INFO}

Regards,
DevOps Team""", 
        cc: "${env.DEV_TEAM}", 
        from: '', 
        replyTo: '', 
        subject: "Jenkins Build Failed: ${env.JOB_NAME}", 
        to: 'dasswagatika411@gmail.com'
        }
        always {
            echo "Cleaning the workspace"
            cleanWs()
        }
    }
} 
